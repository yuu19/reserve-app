    "eas:build:preview:android": "eas build --platform android --profile preview",
    "eas:build:production:ios": "eas build --platform ios --profile production",
    "eas:build:production:android": "eas build --platform android --profile production",
    "eas:submit:ios": "eas submit --platform ios --profile production",
    "eas:submit:android": "eas submit --platform android --profile production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",

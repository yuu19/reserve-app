{
	"name": "@apps/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"cf:dev": "wrangler dev --port 4173",
		"cf:deploy": "pnpm build && wrangler deploy",
		"cf:tail": "wrangler tail",
		"cf:types": "wrangler types",
		"build": "vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && eslint .",
		"clean": "rm -rf .svelte-kit build .turbo",
		"check": "pnpm run typecheck",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"gen": "wrangler types",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test:unit": "vitest",
		"test:watch": "vitest --project server",
		"test": "vitest run --project server"
	},
	"dependencies": {
		"@sentry/sveltekit": "^10.39.0",
		"dayjs": "^1.11.19",
		"hono": "^4.11.7",
		"svelte-sonner": "^1.0.7"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.1",
		"@eslint/js": "^9.39.2",
		"@internationalized/date": "^3.11.0",
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.0.18",
		"bits-ui": "^2.15.5",
		"clsx": "^2.1.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.1.0",
		"playwright": "^1.58.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.48.2",
		"svelte-check": "^4.3.5",
		"sveltekit-superforms": "^2.29.1",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.53.1",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2",
		"wrangler": "^4.60.0",
		"zod": "^4.3.6"
	}
}

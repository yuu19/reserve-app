BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173,mobile://
# Prod: .wakureserve.com / Staging: .stg.wakureserve.com
BETTER_AUTH_COOKIE_DOMAIN=

# Google OAuth (OIDC)
# Redirect URI examples:
# - Local: http://localhost:3000/api/auth/callback/google
# - Prod: https://api.wakureserve.com/api/auth/callback/google
# - Staging: https://api.stg.wakureserve.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend invitation email
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
INVITATION_ACCEPT_URL_BASE=http://localhost:5173/invitations/accept
PARTICIPANT_INVITATION_ACCEPT_URL_BASE=http://localhost:5173/participants/invitations/accept
WEB_BASE_URL=http://localhost:5173
PUBLIC_EVENTS_ORGANIZATION_SLUG=public-events
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Organization logo upload
ORG_LOGO_MAX_UPLOAD_BYTES=5242880
# Optional: direct public base URL for logos (e.g. https://assets.wakureserve.com)
# If empty, backend logo proxy URL is stored in organization.logo
ORG_LOGO_PUBLIC_BASE_URL=

# Service image upload (signed URL)
# Defaults:
# - Upload signing secret: BETTER_AUTH_SECRET
# - Storage bucket: ORG_LOGO_BUCKET (unless SERVICE_IMAGE_BUCKET binding is configured)
SERVICE_IMAGE_MAX_UPLOAD_BYTES=8388608
SERVICE_IMAGE_UPLOAD_TOKEN_TTL_SECONDS=300
SERVICE_IMAGE_UPLOAD_SIGNING_SECRET=
# Optional: direct public base URL for service images (e.g. https://assets.wakureserve.com/services)
# If empty, backend delivery URL is stored in service.imageUrl
SERVICE_IMAGE_PUBLIC_BASE_URL=

# Sentry
SENTRY_DSN_BACKEND=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
